# Ignore Python cache files
__pycache__/
*.py[cod]

# Ignore macOS .DS_Store files
.DS_Store

# Ignore virtual environment directories (optional, if you use venv)
venv/
env/

# Ignore other common Python-related files
*.pyo
*.pyd
*.pdb

# CacheManager sidecar lock files
patriot_center_backend/data/*.json.lock

# Atomic write temp files
patriot_center_backend/data/.tmp_*.json

# Backups created on save
patriot_center_backend/data/*.bak